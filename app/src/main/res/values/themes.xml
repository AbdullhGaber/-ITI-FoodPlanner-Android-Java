<resources>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FDF7F2</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_google_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.FoodPlannerApp</item>
    </style>
    <!-- Base application theme. -->
    <style name="Base.Theme.FoodPlannerApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="colorSecondaryContainer">@color/creamy100</item>
    </style>

    <style name="ShapeAppearance.AreaFlag" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>

    <style name="RoundedImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="CustomMaterialCalendar" parent="ThemeOverlay.MaterialComponents.MaterialCalendar">
        <item name="colorSurface">@color/creamy</item>

        <item name="colorPrimary">@color/orange</item>

        <item name="colorOnPrimary">@color/white</item>

        <item name="colorOnSurface">@color/dark_charcoal</item>
    </style>

    <style name="Theme.FoodPlannerApp" parent="Base.Theme.FoodPlannerApp" />
</resources>