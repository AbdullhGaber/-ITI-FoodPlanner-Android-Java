<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp">

    <ImageView
        android:id="@+id/iv_ingredient"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:padding="8dp"
        android:scaleType="fitCenter"
        tools:src="@drawable/ic_launcher_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_ingredient_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_medium"
        android:textColor="#2E2E2E"
        android:textSize="16sp"
        android:maxLines="1"
        android:gravity="top|center_horizontal"
        android:ellipsize="end"
        tools:text="Penne Rigate"
        app:layout_constraintTop_toBottomOf="@+id/iv_ingredient"
        app:layout_constraintStart_toStartOf="@+id/iv_ingredient"
        app:layout_constraintEnd_toEndOf="@+id/iv_ingredient" />

    <TextView
        android:id="@+id/tv_measure"
        android:layout_width="0dp"
        android:textSize="14sp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="4dp"
        tools:text="1/2 cup"
        android:maxLines="1"
        android:fontFamily="@font/poppins_bold_italic"
        android:textColor="@color/orange"
        app:layout_constraintEnd_toEndOf="@+id/tv_ingredient_name"
        app:layout_constraintStart_toStartOf="@+id/tv_ingredient_name"
        app:layout_constraintTop_toBottomOf="@id/tv_ingredient_name" />

</androidx.constraintlayout.widget.ConstraintLayout>