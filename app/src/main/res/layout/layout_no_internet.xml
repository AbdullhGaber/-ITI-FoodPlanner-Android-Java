<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/no_internet_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/creamy"
    android:visibility="gone">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_no_internet"
        android:layout_width="250dp"
        android:layout_height="250dp"
        app:layout_constraintBottom_toTopOf="@id/tv_no_internet_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:lottie_autoPlay="true"
        app:lottie_loop="false"
        app:lottie_rawRes="@raw/no_wifi" />

    <TextView
        android:id="@+id/tv_no_internet_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/poppins_bold"
        android:text="Whoops!"
        android:textColor="@color/dark_charcoal"
        android:textSize="22sp"
        app:layout_constraintBottom_toTopOf="@id/tv_no_internet_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lottie_no_internet" />

    <TextView
        android:id="@+id/tv_no_internet_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/poppins_medium"
        android:text="No internet connection found.\nCheck your connection and try again."
        android:textAlignment="center"
        android:textColor="@color/olive_grey"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/btn_retry_connection"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_no_internet_title" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_retry_connection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/orange"
        android:fontFamily="@font/poppins_bold"
        android:text="Retry"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/tv_no_internet_subtitle"
        app:layout_constraintStart_toStartOf="@+id/tv_no_internet_subtitle"
        app:layout_constraintTop_toBottomOf="@id/tv_no_internet_subtitle" />

</androidx.constraintlayout.widget.ConstraintLayout>