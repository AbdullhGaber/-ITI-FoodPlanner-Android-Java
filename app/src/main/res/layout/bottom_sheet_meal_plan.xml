<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/creamy"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add to Meal Plan"
        android:textColor="@color/green_header"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Choose when you want to have this meal"
        android:textColor="@color/olive_grey"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <TextView
        android:id="@+id/tvSelectDateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Select Date"
        android:textColor="@color/green_header"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

    <LinearLayout
        android:id="@+id/dateContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_date_container"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectDateLabel">

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tuesday, February 17, 2026"
            android:textColor="@color/green_header"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnChangeDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/light_sand"
            android:drawableLeft="@android:drawable/ic_menu_today"
            android:drawableTint="@color/green_header"
            android:text="Change Date"
            android:textColor="@color/green_header"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSelectMealTypeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Select Meal Type"
        android:textColor="@color/green_header"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dateContainer" />

    <RadioGroup
        android:id="@+id/rgMealType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectMealTypeLabel">

        <RadioButton
            android:id="@+id/rbBreakfast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/green_header"
            android:text="Breakfast"
            android:textColor="@color/dark_charcoal" />

        <RadioButton
            android:id="@+id/rbLunch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:buttonTint="@color/green_header"
            android:text="Lunch"
            android:textColor="@color/dark_charcoal" />

        <RadioButton
            android:id="@+id/rbDinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:buttonTint="@color/green_header"
            android:text="Dinner"
            android:textColor="@color/dark_charcoal" />
    </RadioGroup>

    <Button
        android:id="@+id/btnAddToPlan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/green_header"
        android:text="Add to Plan"
        android:textColor="@color/white"
        app:cornerRadius="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rgMealType" />

    <TextView
        android:id="@+id/tvCancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:text="Cancel"
        android:textColor="@color/olive_grey"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnAddToPlan"
        app:layout_constraintEnd_toStartOf="@id/btnAddToPlan"
        app:layout_constraintTop_toTopOf="@id/btnAddToPlan" />

</androidx.constraintlayout.widget.ConstraintLayout>